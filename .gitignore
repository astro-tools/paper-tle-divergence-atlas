# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual envs
.venv/
env/
venv/

# Jupyter
.ipynb_checkpoints/

# Editor / OS
.vscode/
.idea/
.DS_Store
Thumbs.db

# showyourwork artifacts
.showyourwork/
.snakemake/

# Generated manuscript artifacts
/ms.pdf
/ms.aux
/ms.log
/ms.out
/ms.bbl
/ms.blg
/ms.synctex.gz
/ms.fdb_latexmk
/ms.fls
/ms.toc
# Gitignore everything in figures/ except .gitkeep so the dir exists
# (showyourwork's post-build cache step writes last_commit_sha.txt here)
src/tex/figures/*
!src/tex/figures/.gitkeep
src/tex/_minted-*/

# Sweep outputs (large; deposited on Zenodo).
# Use `outputs/*` (not `outputs/`) so we can re-include specific small
# artifacts below — a directory-style exclusion can't be reopened by a
# per-file negation (see `man gitignore`).
outputs/*
# Exception: small, deterministic corpus subsets we commit so downstream
# sensitivity studies (#28 CdA, #31 maneuver-threshold) don't each have
# to regenerate the same 1k-pair sample.
!outputs/sensitivity_subset_pair_ids.txt

# Sweep manifest from smoke/dev runs. The final sweep's manifest.jsonl gets
# force-added (`git add -f`) when the production sweep is locked, per the
# Day-3/4 acceptance contract.
sweep/manifest.jsonl

# Raw Space-Track TLE dump (~100 MB; one-time fetch, not for commit).
# The post-sample corpus (src/static/tles_cache.parquet) IS committed.
src/data/tles_raw.parquet
src/data/_validate_pairs.png

# Raw GCAT satcat dump (~18 MB; one-time fetch via `make fetch-satcat`).
# Per-NORAD-ID props derived from this are baked into tles_cache.parquet.
src/data/gcat_satcat.tsv

# Local TLE / data caches (small; can be committed if useful)
*.tle.cache
*.parquet.cache

# Conda
.conda/

# Local secrets (Space-Track credentials, etc.)
.env
.env.local
